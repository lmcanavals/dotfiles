#!/usr/bin/env python3

import os
import sys
import json
import re
import argparse
import subprocess
from pathlib import Path
from typing import Dict, Any, List, Set

from PySide6.QtWidgets import (
    QApplication,
    QMainWindow,
    QTableWidgetItem,
    QInputDialog,
    QMessageBox,
    QComboBox,
    QWidget,
    QStyledItemDelegate,
    QTabWidget,
    QTableWidget,
    QPushButton,
)
from PySide6.QtDesigner import QFormBuilder
from PySide6.QtCore import QFile, Qt, QIODevice
from PySide6.QtGui import QColor, QKeySequence, QShortcut, QIcon, QPixmap


def get_home_path(*parts):
    return os.path.join(os.path.expanduser("~"), *parts)


# Path to the directory where JSON themes are stored
THEME_DIR = get_home_path(".config", "themes", "definitions")
THEME_DIR_PATH = Path(THEME_DIR)
DEFAULT_COLOR = "#00ff00"
MISSING_VAL_MARKER = "<missing>"
FOR_PATTERN = re.compile(r"^\s*for\s+(\w+)\s*,\s*(\w+)\s+in\s+(\w+)\s*$")


def load_themes():
    """Dynamically reads all JSON theme files from the definitions folder."""
    themes = {}
    if not os.path.exists(THEME_DIR):
        os.makedirs(THEME_DIR, exist_ok=True)
        return themes

    for filename in os.listdir(THEME_DIR):
        if filename.endswith(".json"):
            theme_id = os.path.splitext(filename)[0]
            path = os.path.join(THEME_DIR, filename)
            try:
                with open(path, "r", encoding="utf-8") as f:
                    themes[theme_id] = json.load(f)
            except Exception as e:
                print(f"Failed to parse '{filename}': {e}", file=sys.stderr)
    return themes


def write_file(path, content):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(content)
    print(f"Written: {path}")


def resolve_theme_colors(theme):
    """Resolves and normalizes colors in a theme dict to raw hex strings without '#'."""
    colors = theme.get("colors", {})
    palette = {k: v.lstrip("#").lower() for k, v in theme.get("palette", {}).items()}

    return {
        k: (palette[v] if v in palette else v).lstrip("#").lower()
        for k, v in colors.items()
    }


def parse_target_path(first_line: str) -> str:
    line = first_line.strip()
    if line.startswith("/*") and line.endswith("*/"):
        line = line[2:-2].strip()
    pos = line.find("target:")
    if pos >= 0:
        return line[pos + 7 :].strip()
    return ""


def parse_reload_cmd(second_line: str) -> list[str]:
    line = second_line.strip()
    if line.startswith("/*") and line.endswith("*/"):
        line = line[2:-2].strip()
    pos = line.find("reload:")
    if pos >= 0:
        return line[pos + 7 :].strip().split()
    return []


def eval_condition(cond_str: str, context: dict) -> bool:
    cond_str = cond_str.strip()
    if "==" in cond_str:
        parts = cond_str.split("==", 1)
        lhs = parts[0].strip()
        rhs = parts[1].strip().strip("\"'")
        val = context.get(lhs, "")
        return str(val) == rhs
    elif "!=" in cond_str:
        parts = cond_str.split("!=", 1)
        lhs = parts[0].strip()
        rhs = parts[1].strip().strip("\"'")
        val = context.get(lhs, "")
        return str(val) != rhs
    else:
        val = context.get(cond_str)
        return bool(val and val != "false" and val != "0")


def parse_template(lines: list) -> list:
    def parse_rec(start_i: int) -> tuple[list, int]:
        nodes = []
        i = start_i
        n = len(lines)
        while i < n:
            line = lines[i]
            strip_line = line.strip()
            if strip_line.startswith("{%") and strip_line.endswith("%}"):
                content = strip_line[2:-2].strip()
                if content.startswith("endfor") or content.startswith("endif"):
                    return nodes, i
                elif content.startswith("for "):
                    match = FOR_PATTERN.match(content)
                    if not match:
                        raise ValueError(f"Invalid for loop syntax: '{strip_line}'")
                    key_var, val_var, dict_var = match.groups()
                    children, end_i = parse_rec(i + 1)
                    actual_end_i = end_i
                    if actual_end_i >= n:
                        raise ValueError(f"Unclosed for loop starting at line {i + 1}")
                    end_strip = lines[actual_end_i].strip()
                    if not (
                        end_strip.startswith("{%")
                        and end_strip.endswith("%}")
                        and "endfor" in end_strip
                    ):
                        raise ValueError(
                            f"Expected {{% endfor %}} at line {actual_end_i + 1}, got '{end_strip}'"
                        )
                    nodes.append(
                        {
                            "type": "for",
                            "key_var": key_var,
                            "val_var": val_var,
                            "dict_var": dict_var,
                            "children": children,
                        }
                    )
                    i = actual_end_i + 1
                elif content.startswith("if "):
                    cond_str = content[3:].strip()
                    children, end_i = parse_rec(i + 1)
                    actual_end_i = end_i
                    if actual_end_i >= n:
                        raise ValueError(f"Unclosed if block starting at line {i + 1}")
                    end_strip = lines[actual_end_i].strip()
                    if not (
                        end_strip.startswith("{%")
                        and end_strip.endswith("%}")
                        and "endif" in end_strip
                    ):
                        raise ValueError(
                            f"Expected {{% endif %}} at line {actual_end_i + 1}, got '{end_strip}'"
                        )
                    nodes.append(
                        {"type": "if", "condition": cond_str, "children": children}
                    )
                    i = actual_end_i + 1
                else:
                    raise ValueError(f"Unknown template directive: {strip_line}")
            else:
                nodes.append({"type": "text", "text": line})
                i += 1
        return nodes, i

    nodes, last_i = parse_rec(0)
    if last_i < len(lines):
        bad_line = lines[last_i].strip()
        raise ValueError(f"Unmatched end directive: '{bad_line}'")
    return nodes


def evaluate_nodes(nodes: list, context: dict, unknown_variables: set) -> str:
    result = []

    def resolve_placeholders(text: str, local_ctx: dict) -> str:
        def replace_match(match):
            var_name = match.group(1).strip()
            if var_name in local_ctx:
                return str(local_ctx[var_name])
            else:
                unknown_variables.add(var_name)
                return f"{{{{{var_name}}}}}"

        return re.sub(r"\{\{([^}]+)\}\}", replace_match, text)

    for node in nodes:
        ntype = node["type"]
        if ntype == "text":
            result.append(resolve_placeholders(node["text"], context))
        elif ntype == "if":
            if eval_condition(node["condition"], context):
                result.append(
                    evaluate_nodes(node["children"], context, unknown_variables)
                )
        elif ntype == "for":
            dict_var = node["dict_var"]
            key_var = node["key_var"]
            val_var = node["val_var"]

            target_dict = context.get(dict_var)
            if not isinstance(target_dict, dict):
                unknown_variables.add(dict_var)
                continue

            for k, v in target_dict.items():
                loop_ctx = context.copy()
                loop_ctx[key_var] = k
                loop_ctx[val_var] = v
                result.append(
                    evaluate_nodes(node["children"], loop_ctx, unknown_variables)
                )

    return "".join(result)


def apply_theme(theme_id, themes):
    if theme_id not in themes:
        print(f"Error: Theme '{theme_id}' not found.")
        sys.exit(1)

    theme = themes[theme_id]
    c = resolve_theme_colors(theme)
    print(f"Applying theme: {theme['name']}...")

    # Build context
    context = {}
    for k, v in theme.items():
        if k not in ("palette", "colors"):
            context[k] = str(v)
    for k, v in c.items():
        context[k] = str(v)
    context["colors"] = c

    templates_dir = get_home_path(".config", "themes", "templates")
    if not os.path.exists(templates_dir) or not os.listdir(templates_dir):
        print(
            f"Error: Templates directory '{templates_dir}' is missing or empty. Please populate it.",
            file=sys.stderr,
        )
        sys.exit(1)

    failures = []

    for filename in sorted(os.listdir(templates_dir)):
        template_path = os.path.join(templates_dir, filename)
        if not os.path.isfile(template_path):
            continue

        try:
            with open(template_path, "r", encoding="utf-8") as f:
                template_content = f.read()
        except Exception as e:
            failures.append(f"Failed to read template '{filename}': {e}")
            continue

        lines = template_content.splitlines(keepends=True)
        if not lines:
            failures.append(f"Template '{filename}' is empty.")
            continue

        target_path = parse_target_path(lines[0])
        reload_cmd = parse_reload_cmd(lines[1])
        if not target_path:
            failures.append(
                f"Template '{filename}' lacks a valid 'target: <path>' directive on the first line."
            )
            continue

        template_body = "".join(lines[2 if reload_cmd else 1 :])
        unknown_vars = set()
        try:
            nodes = parse_template(template_body.splitlines(keepends=True))
            rendered_content = evaluate_nodes(nodes, context, unknown_vars)
        except Exception as e:
            failures.append(f"Failed to render template '{filename}': {e}")
            continue

        if unknown_vars:
            failures.append(
                f"Template '{filename}' has unknown variables: {', '.join(sorted(unknown_vars))}"
            )

        expanded_target = os.path.expanduser(target_path)
        try:
            write_file(expanded_target, rendered_content)
            if reload_cmd:
                try:
                    subprocess.run(reload_cmd, stderr=subprocess.DEVNULL)
                    print(f"Reloading '{expanded_target}' corresponding app.")
                except Exception:
                    failures.append(f"Couldn't reload '{filename}' corresponding app.")
        except Exception as e:
            failures.append(
                f"Failed to write rendered '{filename}' to '{expanded_target}': {e}"
            )

    if failures:
        print("\n--- Theme Application Report ---", file=sys.stderr)
        for fail in failures:
            print(f"Error/Warning: {fail}", file=sys.stderr)
        print("--------------------------------\n", file=sys.stderr)

    print("Theme applied successfully!")


def run_fzf_selector(themes):
    # Verify FZF is installed
    try:
        subprocess.run(
            ["fzf", "--version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
    except FileNotFoundError:
        print("Error: 'fzf' is not installed or not in PATH.")
        sys.exit(1)

    themes_input = "\n".join(themes.keys())

    try:
        proc = subprocess.Popen(
            ["fzf", "--ansi", "--prompt=Select System Theme > "],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            text=True,
        )
        stdout, _ = proc.communicate(input=themes_input)
        selected = stdout.strip()
        if selected:
            apply_theme(selected, themes)
        else:
            print("Selection cancelled.")
    except Exception as e:
        print(f"Error running fzf: {e}")
        sys.exit(1)


class ColorMappingDelegate(QStyledItemDelegate):
    def __init__(self, parent=None):
        super().__init__(parent)
        self.palette_items = []

    def set_palette_items(self, items):
        """Updates the dropdown autocomplete source list context dynamically."""
        self.palette_items = sorted(list(items))

    def createEditor(self, parent, option, index):
        # Index column 0 is the row schema label; we don't place a custom dropdown editor there
        if index.column() == 0:
            return super().createEditor(parent, option, index)

        editor = QComboBox(parent)
        editor.setEditable(True)  # Allows fallback hex typing overrides directly

        # Add literal names and standard prefixed mappings cleanly
        formatted_items = list(self.palette_items)

        editor.addItems(formatted_items)
        return editor

    def setEditorData(self, editor, index):
        model = index.model()
        if model:
            value = model.data(index, Qt.ItemDataRole.EditRole)
            if value:
                editor.setCurrentText(str(value))

    def setModelData(self, editor, model, index):
        model.setData(index, editor.currentText(), Qt.ItemDataRole.EditRole)


class ThemeEditor(QMainWindow):
    def __init__(self):
        super().__init__()
        self.themes: Dict[str, Dict[str, Any]] = {}
        self.theme_ids: List[str] = []

        # 1. Load the UI safely using QFormBuilder
        ui_path = Path(__file__).parent / "main_window.ui"
        ui_file = QFile(str(ui_path))
        if not ui_file.open(QIODevice.OpenModeFlag.ReadOnly):
            print(f"Error: Cannot open main_window.ui at {ui_path}", file=sys.stderr)
            sys.exit(1)

        builder = QFormBuilder()
        # Load as a generic widget container instead of passing 'self'
        self.ui_container = builder.load(ui_file)
        ui_file.close()

        if not self.ui_container:
            print("Error: Failed to load UI layout data structure.", file=sys.stderr)
            sys.exit(1)

        # 2. Extract widgets from the container wrapper using findChild and assert not None
        tab_widget = self.ui_container.findChild(QTabWidget, "tabWidget")
        assert tab_widget is not None
        self.tab_widget = tab_widget

        color_table = self.ui_container.findChild(QTableWidget, "colorTable")
        assert color_table is not None
        self.color_table = color_table

        meta_table = self.ui_container.findChild(QTableWidget, "metaTable")
        assert meta_table is not None
        self.meta_table = meta_table

        add_key_button = self.ui_container.findChild(QPushButton, "addKeyButton")
        assert add_key_button is not None
        self.add_key_button = add_key_button

        new_theme_button = self.ui_container.findChild(QPushButton, "newThemeButton")
        assert new_theme_button is not None
        self.new_theme_button = new_theme_button

        apply_theme_button = self.ui_container.findChild(
            QPushButton, "applyThemeButton"
        )
        assert apply_theme_button is not None
        self.apply_theme_button = apply_theme_button

        # Set up the main window CentralWidget
        central_widget = self.ui_container.findChild(QWidget, "centralWidget")
        assert central_widget is not None
        self.setCentralWidget(central_widget)

        self.setWindowTitle("THM-EDIT ── Theme Configuration Studio")
        self.resize(900, 650)

        # Setup specific inline column delegates
        self.color_delegate = ColorMappingDelegate(self)
        self.color_table.setItemDelegate(self.color_delegate)

        # 3. Connect system action slots
        self.add_key_button.clicked.connect(self.handle_add_key)
        self.new_theme_button.clicked.connect(self.handle_create_theme)
        self.apply_theme_button.clicked.connect(self.handle_apply_theme)
        self.color_table.cellChanged.connect(self.handle_color_cell_changed)
        self.meta_table.cellChanged.connect(self.handle_meta_cell_changed)

        # Standard close application binding setup
        quit_shortcut = QShortcut(QKeySequence("Ctrl+Q"), self)
        quit_shortcut.activated.connect(self.close)

        # 4. Initialize Core Data Pipelines
        self.load_all_themes_from_disk()
        self.populate_grids()

    def get_color_item(self, row: int, col: int) -> QTableWidgetItem:
        item = self.color_table.item(row, col)
        assert item is not None
        return item

    def get_meta_item(self, row: int, col: int) -> QTableWidgetItem:
        item = self.meta_table.item(row, col)
        assert item is not None
        return item

    def load_all_themes_from_disk(self):
        THEME_DIR_PATH.mkdir(parents=True, exist_ok=True)
        self.themes = {}
        for path in THEME_DIR_PATH.glob("*.json"):
            theme_id = path.stem
            try:
                with open(path, "r", encoding="utf-8") as f:
                    self.themes[theme_id] = json.load(f)
            except Exception as e:
                print(f"Failed loading theme {theme_id}: {e}")
        self.theme_ids = sorted(list(self.themes.keys()))

    def save_all_themes_to_disk(self):
        THEME_DIR_PATH.mkdir(parents=True, exist_ok=True)
        for theme_id, data in self.themes.items():
            path = THEME_DIR_PATH / f"{theme_id}.json"
            try:
                with open(path, "w", encoding="utf-8") as f:
                    json.dump(data, f, indent=4)
            except Exception as e:
                QMessageBox.critical(
                    self, "Disk Write Error", f"Could not write {theme_id}.json:\n{e}"
                )

    def get_all_color_keys(self) -> List[str]:
        keys: Set[str] = set()
        for t in self.themes.values():
            keys.update(t.get("colors", {}).keys())
        return sorted(list(keys))

    def get_all_meta_keys(self) -> List[str]:
        keys: Set[str] = set()
        protected = {"colors", "palette"}
        for t in self.themes.values():
            keys.update(k for k in t.keys() if k not in protected)
        return sorted(list(keys))

    def populate_grids(self):
        self.color_table.blockSignals(True)
        self.meta_table.blockSignals(True)

        color_keys = self.get_all_color_keys()
        meta_keys = self.get_all_meta_keys()

        color_headers = ["colors"] + self.theme_ids
        meta_headers = ["properties"] + self.theme_ids

        # --- Build Color Schemes Grid ---
        self.color_table.setColumnCount(len(color_headers))
        self.color_table.setRowCount(len(color_keys))
        self.color_table.setHorizontalHeaderLabels(color_headers)

        for row, r_key in enumerate(color_keys):
            item = QTableWidgetItem(r_key)
            item.setFlags(
                Qt.ItemFlag.ItemIsEnabled
                | Qt.ItemFlag.ItemIsSelectable
                | Qt.ItemFlag.ItemIsEditable
            )
            item.setData(Qt.ItemDataRole.UserRole, r_key)
            self.color_table.setItem(row, 0, item)

            for col, tid in enumerate(self.theme_ids, start=1):
                theme = self.themes[tid]
                colors_dict = theme.setdefault("colors", {})
                val = colors_dict.setdefault(r_key, DEFAULT_COLOR)
                cell_item = QTableWidgetItem(val)
                resolved_hex = self.resolve_hex(val, theme.get("palette", {}))
                cell_item.setBackground(QColor(f"#{resolved_hex}"))
                cell_item.setIcon(self.create_color_icon(resolved_hex))

                self.color_table.setItem(row, col, cell_item)

        # --- Build Application Meta Grid ---
        self.meta_table.setColumnCount(len(meta_headers))
        self.meta_table.setRowCount(len(meta_keys))
        self.meta_table.setHorizontalHeaderLabels(meta_headers)

        for row, r_key in enumerate(meta_keys):
            self.meta_table.setItem(row, 0, QTableWidgetItem(r_key))
            item_meta = self.meta_table.item(row, 0)
            assert item_meta is not None
            item_meta.setFlags(Qt.ItemFlag.ItemIsEnabled | Qt.ItemFlag.ItemIsSelectable)

            for col, tid in enumerate(self.theme_ids, start=1):
                theme = self.themes[tid]
                val = theme.setdefault(r_key, MISSING_VAL_MARKER)
                self.meta_table.setItem(row, col, QTableWidgetItem(str(val)))

        # Connect Dynamic Interactive Dropdown Hooks
        self.color_table.currentCellChanged.connect(self.update_delegate_palette_scope)

        self.color_table.resizeColumnsToContents()
        self.meta_table.resizeColumnsToContents()

        self.color_table.blockSignals(False)
        self.meta_table.blockSignals(False)

    def update_delegate_palette_scope(self, _row, col, _old_row, _old_col):
        if col < 1 or col > len(self.theme_ids):
            return
        target_theme_id = self.theme_ids[col - 1]
        palette_dict = self.themes[target_theme_id].get("palette", {})
        self.color_delegate.set_palette_items(palette_dict.keys())

    def resolve_hex(self, val: str, palette: Dict[str, str]) -> str:
        if val.startswith("palette."):
            print("xxxxxxxxxxxx")
            pk = val.split(".")[1]
            return palette.get(pk, "ffffff").lstrip("#")
        if val in palette:
            return palette.get(val, "ffffff").lstrip("#")
        return val.lstrip("#")

    def create_color_icon(self, hex_str: str) -> QIcon:
        color = QColor(f"#{hex_str}") if len(hex_str) in (3, 6) else QColor("#00ff00")
        pixmap = QPixmap(16, 16)
        pixmap.fill(color)
        return QIcon(pixmap)

    def handle_color_cell_changed(self, row, col):
        if col == 0:
            item = self.get_color_item(row, 0)
            new_key = item.text().strip()
            old_key = item.data(Qt.ItemDataRole.UserRole)

            if not old_key:
                return
            if new_key == old_key:
                return

            if not new_key:
                QMessageBox.warning(self, "Invalid Key", "Color key cannot be empty.")
                self.color_table.blockSignals(True)
                item.setText(old_key)
                self.color_table.blockSignals(False)
                return

            # Rename key across all themes
            for theme in self.themes.values():
                colors_dict = theme.setdefault("colors", {})
                if old_key in colors_dict:
                    val = colors_dict.pop(old_key)
                    colors_dict[new_key] = val

            self.save_all_themes_to_disk()
            item.setData(Qt.ItemDataRole.UserRole, new_key)
            self.populate_grids()
            return

        tid = self.theme_ids[col - 1]
        row_key = self.get_color_item(row, 0).text()
        new_val = self.get_color_item(row, col).text().strip()

        self.themes[tid]["colors"][row_key] = new_val

        self.color_table.blockSignals(True)
        resolved_hex = self.resolve_hex(new_val, self.themes[tid].get("palette", {}))
        self.get_color_item(row, col).setBackground(QColor(f"#{resolved_hex}"))
        self.get_color_item(row, col).setIcon(self.create_color_icon(resolved_hex))
        self.color_table.blockSignals(False)

        self.save_all_themes_to_disk()

    def handle_meta_cell_changed(self, row, col):
        if col == 0:
            return
        tid = self.theme_ids[col - 1]
        row_key = self.get_meta_item(row, 0).text()
        new_val = self.get_meta_item(row, col).text().strip()

        self.themes[tid][row_key] = new_val
        self.save_all_themes_to_disk()

    def handle_add_key(self):
        current_tab_idx = self.tab_widget.currentIndex()
        prompt_title = (
            "New Color Key Mapping"
            if current_tab_idx == 0
            else "New Configuration Parameter"
        )
        prompt_label = "Enter structural key dictionary identifier:"

        new_key, ok = QInputDialog.getText(self, prompt_title, prompt_label)
        if not ok or not new_key.strip():
            return

        new_key = new_key.strip()
        for t in self.themes.values():
            if current_tab_idx == 0:
                t.setdefault("colors", {})[new_key] = DEFAULT_COLOR
            else:
                t[new_key] = MISSING_VAL_MARKER

        self.save_all_themes_to_disk()
        self.populate_grids()

    def handle_create_theme(self):
        theme_id, ok = QInputDialog.getText(
            self, "New Theme Template", "Enter Unique Filename File ID:"
        )
        if not ok or not theme_id.strip():
            return

        theme_id = theme_id.replace(".json", "").strip()
        skeleton = {
            "name": f"{theme_id.title()} Template Scheme",
            "light_or_dark": "dark",
            "palette": {
                "background": "#1a1a1a",
                "foreground": "#e0e0e0",
                "accent": "#00ff00",
            },
            "colors": {
                "bg": "background",
                "fg": "foreground",
            },
        }
        self.themes[theme_id] = skeleton
        self.save_all_themes_to_disk()
        self.load_all_themes_from_disk()
        self.populate_grids()

    def handle_apply_theme(self):
        current_tab_idx = self.tab_widget.currentIndex()
        table = self.color_table if current_tab_idx == 0 else self.meta_table
        current_col = table.currentColumn()

        if current_col < 1 or current_col > len(self.theme_ids):
            QMessageBox.warning(
                self,
                "Select Theme",
                "Please select a cell in a theme's column first to apply it.",
            )
            return

        theme_id = self.theme_ids[current_col - 1]
        theme_name = self.themes[theme_id].get("name", theme_id)

        try:
            self.save_all_themes_to_disk()
            apply_theme(theme_id, self.themes)
            self.statusBar().showMessage(f"Applied theme: {theme_name}", 5000)
        except Exception as e:
            QMessageBox.critical(
                self, "Apply Theme Error", f"Failed to apply theme '{theme_id}':\n{e}"
            )

    def closeEvent(self, event):
        self.save_all_themes_to_disk()
        event.accept()


def run_gui():
    app = QApplication(sys.argv)
    window = ThemeEditor()
    window.show()
    sys.exit(app.exec())


def main():
    if (
        os.path.basename(sys.argv[0]) == "thmedit"
        or "--gui" in sys.argv
        or "-g" in sys.argv
    ):
        run_gui()
        sys.exit(0)

    themes = load_themes()

    parser = argparse.ArgumentParser(description="Centralized theme switcher.")
    subparsers = parser.add_subparsers(dest="command")

    # thm list
    subparsers.add_parser("list", help="List all available themes")

    # thm set <theme>
    set_parser = subparsers.add_parser("set", help="Set active theme")
    set_parser.add_argument("theme_name", type=str, help="Theme ID to apply")

    # thm select
    subparsers.add_parser("select", help="Interactively select a theme using fzf")

    # thm gui / edit
    subparsers.add_parser("gui", help="Launch the GUI Theme Configuration Studio")
    subparsers.add_parser("edit", help="Launch the GUI Theme Configuration Studio")

    args = parser.parse_args()

    if not themes:
        print(f"No themes found in '{THEME_DIR}'. Please add JSON theme files.")
        sys.exit(1)

    if args.command in ("gui", "edit") or args.command is None:
        run_gui()
    elif args.command == "list":
        print("Available Themes:")
        for tid, tinfo in themes.items():
            print(f"  - {tid:<20} ({tinfo.get('name', 'Unknown')})")
    elif args.command == "set":
        apply_theme(args.theme_name, themes)
    elif args.command == "select":
        run_fzf_selector(themes)


if __name__ == "__main__":
    main()
