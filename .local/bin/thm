def get_home_path(*parts):
    return os.path.join(os.path.expanduser("~"), *parts)


# Path to the directory where JSON themes are stored
THEME_DIR = get_home_path(".config", "themes", "definitions")
THEME_DIR_PATH = Path(THEME_DIR)
DEFAULT_COLOR = "#00ff00"
MISSING_VAL_MARKER = "<missing>"


def load_themes():
    """Dynamically reads all JSON theme files from the definitions folder."""
    themes = {}
    if not os.path.exists(THEME_DIR):
        os.makedirs(THEME_DIR, exist_ok=True)
        return themes

    for filename in os.listdir(THEME_DIR):
        if filename.endswith(".json"):
            theme_id = os.path.splitext(filename)[0]
            path = os.path.join(THEME_DIR, filename)
            try:
                with open(path, "r", encoding="utf-8") as f:
                    themes[theme_id] = json.load(f)
            except Exception as e:
                print(
                    f"Warning: Failed to parse theme file '{filename}': {e}",
                    file=sys.stderr,
                )
    return themes


def write_file(path, content):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        f.write(content)
    print(f"Written: {path}")


def resolve_theme_colors(theme):
    """Resolves and normalizes colors in a theme dict to raw hex strings without '#'."""
    palette = theme.get("palette", {})
    raw_colors = theme.get("colors", {})
    resolved = {}

    # Normalize palette keys and values
    clean_palette = {}
    for k, v in palette.items():
        if isinstance(v, str):
            clean_palette[k] = v.lstrip("#").lower()
        else:
            clean_palette[k] = v

    for key, val in raw_colors.items():
        if isinstance(val, str):
            if val.startswith("palette."):
                palette_key = val.split(".")[1]
                resolved_val = clean_palette.get(palette_key, "ffffff")
            elif val in clean_palette:
                resolved_val = clean_palette[val]
            else:
                resolved_val = val
        else:
            resolved_val = str(val)

        # Normalize the resolved value to lowercase hex without '#'
        resolved[key] = resolved_val.lstrip("#").lower()

    return resolved


def apply_theme(theme_id, themes):
