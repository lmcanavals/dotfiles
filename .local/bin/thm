  --highlight-line \\
  --info=inline-right \\
  --ansi \\
  --layout=reverse \\
  --border=none \\
  --color=bg+:#{c["bg_highlight"]} \\
  --color=bg:#{c["bg"]} \\
  --color=border:#{c["border"]} \\
  --color=fg:#{c["fg"]} \\
  --color=gutter:#{c["bg"]} \\
  --color=header:#{c["accent_alt"]} \\
  --color=hl+:#{c["accent"]} \\
  --color=hl:#{c["accent"]} \\
  --color=info:#{c["comment"]} \\
  --color=marker:#{c["accent_dim"]} \\
  --color=pointer:#{c["accent_dim"]} \\
  --color=prompt:#{c["accent"]} \\
  --color=query:#{c["fg"]}:regular \\
  --color=scrollbar:#{c["accent"]} \\
  --color=separator:#{c["accent_alt"]} \\
