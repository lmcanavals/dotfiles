  --color=fg:#{c["fg"]} \\
  --color=gutter:#{c["bg"]} \\
  --color=header:#{c["accent_alt"]} \\
  --color=hl+:#{c["accent"]} \\
  --color=hl:#{c["accent"]} \\
  --color=info:#{c["comment"]} \\
  --color=marker:#{c["accent_dim"]} \\
  --color=pointer:#{c["accent_dim"]} \\
  --color=prompt:#{c["accent"]} \\
