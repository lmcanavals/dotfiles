#!/usr/bin/env zsh

zmodload zsh/mapfile

typeset -a battery_normal=("󰂎" "󰁺" "󰁻" "󰁼" "󰁽" "󰁾" "󰁿" "󰂀" "󰂁" "󰂂" "󰁹")
typeset -a battery_charging=("󰢟" "󰢜" "󰂆" "󰂇" "󰂈" "󰢝" "󰂉" "󰢞" "󰂊" "󰂋" "󰂅")
local icon_low="󱃍"
local icon_plugged=""
local sys_paths=(/sys/class/power_supply/BAT*(N))

if ((${#sys_paths} == 0)); then
	print -r -- "󰂑 not found"
	exit 1
fi

local bat_dir="${sys_paths[1]}"
local state="${$(<$bat_dir/status):l}"
local -i percentage=$(<$bat_dir/capacity)
local present="${$(<$bat_dir/present):l}"

local -i icon_idx=$((percentage / 9.1 + 1))
local output=""

if [[ "$state" == "full" || "$state" == "not charging" && "$present" == "1" ]]; then
	output="$icon_plugged battery full"
elif [[ "$state" == "charging" ]]; then
	output="${battery_charging[icon_idx]} $percentage%"
elif [[ "$state" == "discharging" && $percentage -lt 25 ]]; then
	output="<span color=\"${LCLR:24:7}\">$icon_low $percentage% </span>"
else
	output="${battery_normal[icon_idx]} $percentage% $state"
fi

print -r -- "$output"
