#!/usr/bin/zsh

display_items=("${(f)$(hyprctl clients -j | jq -r '.[] | "\(.workspace.name):\(.class): \(.title)"')}")
addresses=("${(f)$(hyprctl clients -j | jq -r '.[] | .address')}")

idx=$(printf "%s\n" "${display_items[@]}" | fuzzel -d --index --placeholder=" find a window" --match-mode=fuzzy)

if [ -n "$idx" ]; then
	zsh_idx=$((idx + 1))
	selected_addr="${addresses[$zsh_idx]}"

	hyprctl dispatch "hl.dsp.focus({window=\"address:$selected_addr\"})"
fi
