#!/usr/bin/env zsh

safeupdatemirrors() {
	local base="/etc/pacman.d"
	local tempfile=$(mktemp)
	local mirrorlist="https://archlinux.org/mirrorlist/"
	local countries="country=all"
	local protocol="protocol=https"
	local ip_version="ip_version=4"
	local use_status="use_mirror_status=on"

	echo "Saving new mirrorlist to $tempfile"

	curl -s "$mirrorlist?$countries&$protocol&$ip_version&$use_status" |
		sed -e 's/^#Server/Server/' -e '/^#/d' |
		rankmirrors -w -m 1 -p -n 6 - >$tempfile

	if [ $? -eq 0 ]; then
		echo "We got a nice list"
		sudo cp "$tempfile" "$base/mirrorlist"
		echo "Mirror list updated"
	else
		echo "Failed to update mirror list. Keeping the old one"
	fi
	rm $tempfile
}
safeupdatemirrors
