		"interval": 2,
		"consume-icons": {
			"on": "пГД "
		},
		"random-icons": {
			"off": "<span color=\"#f53c3c\">пБі</span> ",
			"on": "пБі "
		},
		"repeat-icons": {
			"on": "пАЮ "
		},
		"single-icons": {
