	// "width": 1280, // Waybar width
	"height": 30,
	"spacing": 4, // Gaps between modules (4px)
	"modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media"],
	"modules-center": ["sway/window"],
	"modules-right": ["idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "sway/language", "battery", "tray", "clock"],
	// Modules configuration
	"sway/workspaces": {
		"disable-scroll": true,
		"warp-on-scroll": true,
		"format": "{name}: {icon}",
		"format-icons": {
