{
	// "layer": "top", // Waybar at top layer
	// "position": "bottom", // Waybar position (top|bottom|left|right)
	// "width": 1280, // Waybar width
	"height": 30,
	"spacing": 4, // Gaps between modules (4px)
	"modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media"],
	"modules-center": ["sway/window"],
	"modules-right": ["idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "sway/language", "battery", "tray", "clock"],
	// Modules configuration
	"sway/workspaces": {
		"disable-scroll": true,
		"warp-on-scroll": true,
		"format": "{name}: {icon}",
		"format-icons": {
			"1": "ΎΚρ",
			"2": "ΎΕι",
			"3": "ΎΚρ",
			"4": "ΎΕκ",
			"5": "≤▒ζΚ",
			"6": "≤▒Νλ",
			"urgent": "ΎΒς",
			"focused": "ΎΗΤ",
			"default": "ΎΕΣ"
		}
	},
	"keyboard-state": {
		"numlock": true,
		"capslock": true,
		"format": "{name} {icon}",
		"format-icons": {
			"locked": "ΎΑμ",
			"unlocked": "ΎΓε"
		}
	},
	"sway/mode": {
		"format": "{} ΌφΤ"
	},
	"sway/scratchpad": {
		"format": "{icon} {count}",
		"show-empty": false,
		"format-icons": ["", "≤░Ψ▓"],
		"tooltip": true,
		"tooltip-format": "{app}: {title}"
	},
	"sway/language": {
		"format": "{flag}",
		"tooltip-format": "{long}",
	},
	"mpd": {
		"format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) έ╕ρ{songPosition}|{queueLength}έ╕σ {volume}% ΎΑΒ",
		"format-disconnected": "Disconnected ΎΑΒ",
		"format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
		"unknown-tag": "N/A",
		"interval": 2,
		"consume-icons": {
			"on": "ΎΔΕ "
		},
		"random-icons": {
			"off": "<span color=\"#f53c3c\">ΎΒ┤</span> ",
			"on": "ΎΒ┤ "
		},
		"repeat-icons": {
			"on": "ΎΑη "
		},
		"single-icons": {
			"on": "ΎΑη1 "
		},
		"state-icons": {
			"paused": "ΎΒΝ",
			"playing": "ΎΒΜ"
		},
		"tooltip-format": "MPD (connected)",
		"tooltip-format-disconnected": "MPD (disconnected)",
	},
	"idle_inhibitor": {
		"format": "{icon}",
		"format-icons": {
			"activated": "ΎΒχ",
			"deactivated": "ΎΒ░"
		}
	},
	"tray": {
		// "icon-size": 21,
		"spacing": 10
	},
	"clock": {
		// "timezone": "America/New_York",
		"format": "{:%H:%M} ΎΑΩ",
		"format-alt": "{:%a, %d %b, %Y (%R)} ≤▒δκ",
		"tooltip-format": "<span size='10pt' font='monospace'>{calendar}</span>",
		"calendar": {
			"mode"          : "year",
			"mode-mon-col"  : 3,
			"on-scroll"     : 1,
			"on-click-right": "mode",
			"format": {
				"today":      "<span color='Gold'><b><u>{}</u></b></span>"
			}
		},
		"actions": {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		}
	},
	"cpu": {
		"format": "{usage}% ≤░╗ι",
		"tooltip": false
	},
	"memory": {
		"format": "{}% ≤░αγ"
	},
	"temperature": {
		// "thermal-zone": 2,
		// "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
		"critical-threshold": 80,
		"format-critical": "{temperatureC}┬░C {icon}",
		"format": "",
		"format-icons": ["ΎΜΜ", "ΎΜΛ", "ΎΜΚ", "ΎΜΙ", "ΎΜΘ"]
	},
	"backlight": {
		// "device": "acpi_video1",
		"format": "{percent}% {icon}",
		"format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"]
	},
	"battery": {
		"states": {
			"good": 95,
			"warning": 30,
			"critical": 15
		},
		"format": "{capacity}% {icon}",
		"format-charging": "{capacity}% ≤░ΓΕ",
		"format-plugged": "{capacity}% ΎΘο",
		"format-alt": "{time} {icon}",
		"format-good": "{capacity}%", // An empty format will hide the module
		"format-full": "",
		"format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
	},
	"network": {
		// "interface": "wlp2*", // (Optional) To force the use of this interface
		"format-ethernet": "Wired ≤░ΙΑ",
		"format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
		"tooltip-format": "{ifname} via {gwaddr} ≤░λσ",
		"format-linked": "{ifname} (No IP) ≤░Νβ",
		"format-disconnected": "Disconnected έγι",
		"format-alt": "{ifname}: {ipaddr}/{cidr}"
	},
	"pulseaudio": {
		"scroll-step": 2, // %, can be a float
		"format": "{volume}% {icon} {format_source}",
		"format-bluetooth": "{volume}% {icon}ΎΛΦ {format_source}",
		"format-bluetooth-muted": "≤░ζθ {icon}ΎΛΦ {format_source}",
		"format-muted": "≤░ζθ {format_source}",
		"format-source": " {volume}% ΎΕ░",
		"format-source-muted": " ΎΕ▒",
		"format-icons": {
			"headphone": "ΎΑξ",
			"hands-free": "≤▒κΠ",
			"headset": "≤░ΜΟ",
			"phone": "ΎΓΧ",
			"portable": "ΎΓΧ",
			"car": "ΎΗ╣",
			"default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
		},
		"on-click": "pavucontrol"

	},
	"custom/media": {
		"format": "{icon} {}",
		"return-type": "json",
		"max-length": 40,
		"format-icons": {
			"spotify": "ΎΗ╝",
			"default": "≤░▓Σ"
		},
		"escape": true,
		// "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
		"exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
	}
}

